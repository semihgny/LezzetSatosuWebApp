@model cafeSite2.Models.iletisim

@{
    ViewData["Title"] = "Delete";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<h3>Bu kaydı silmek istediğinize emin misiniz?</h3>
<div>

    <dl class="row">
        <dt class = "col-sm-2">
Email       
</dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.eMail)
        </dd>
        <dt class = "col-sm-2">
Telefon        
</dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.telefon)
        </dd>
        <dt class = "col-sm-2">
Adres
</dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.adres)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="id" />
        <input type="submit" value="Sil" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-primary">Kayıt Listesi</a>
    </form>
</div>
